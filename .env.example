# Copy to .env for local-only settings. Never commit your real .env file.
# OpenAI recommends keeping API keys in server-side environment variables.
OPENAI_API_KEY=your_api_key_here

# Future AI provider switch; current app safely falls back to the local stub unless wired otherwise.
AI_TAGGING_PROVIDER=stub
AI_TAGGING_MODEL=gpt-5.4

# Storage-conscious Raspberry Pi defaults.
DETAIL_HARVESTER_DATA_ROOT=data
DETAIL_CROP_FORMAT=webp
DETAIL_CROP_MAX_WIDTH=1800
DETAIL_IMAGE_QUALITY=82
DETAIL_RETAIN_PAGE_IMAGES=false
DETAIL_AUTO_TEMP_CLEANUP=true
DETAIL_RENDER_ZOOM=2.0
